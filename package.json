{
  "name": "shuymn.me",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "node scripts/project-local-content.mjs --check && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "deploy:dry-run": "pnpm run build && wrangler deploy --dry-run --config dist/server/wrangler.json",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "fmt": "biome check --linter-enabled=false --error-on-warnings .",
    "fmt:fix": "biome check --linter-enabled=false --write .",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "project:content": "node scripts/project-local-content.mjs",
    "test:local-content": "node --test scripts/project-local-content.test.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/react": "^5.0.0",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.0.1",
    "lucide-react": "^1.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "use-sync-external-store": "^1.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.4.16",
    "@cloudflare/workers-types": "4.20260611.1",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "lefthook": "2.1.9",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "wrangler": "4.100.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "engines": {
    "node": "24.x"
  }
}
