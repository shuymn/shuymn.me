{
  "$schema": "https://emdashcms.com/seed.schema.json",
  "version": "1",
  "meta": {
    "name": "shuymn.me",
    "description": "Local EmDash schema for shuymn.me",
    "author": "shuymn"
  },
  "settings": {
    "title": "shuymn.me"
  },
  "collections": [
    {
      "slug": "posts",
      "label": "Posts",
      "labelSingular": "Post",
      "supports": ["drafts", "revisions", "search", "seo"],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "description",
          "label": "Description",
          "type": "text",
          "searchable": true
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "searchable": true
        },
        {
          "slug": "english_generation_disabled",
          "label": "Disable English Generation",
          "type": "boolean",
          "defaultValue": false
        },
        {
          "slug": "english_generation_status",
          "label": "English Generation Status",
          "type": "string"
        },
        {
          "slug": "english_generation_source_id",
          "label": "English Generation Source ID",
          "type": "string"
        },
        {
          "slug": "english_generation_source_slug",
          "label": "English Generation Source Slug",
          "type": "string"
        },
        {
          "slug": "english_generation_source_version",
          "label": "English Generation Source Version",
          "type": "string"
        },
        {
          "slug": "english_generation_note_version",
          "label": "English Generation Note Version",
          "type": "string"
        },
        {
          "slug": "english_generation_content_hash",
          "label": "English Generation Content Hash",
          "type": "string"
        },
        {
          "slug": "english_generation_failure_reason",
          "label": "English Generation Failure Reason",
          "type": "text"
        },
        {
          "slug": "english_generation_gate_results",
          "label": "English Generation Gate Results",
          "type": "json"
        }
      ]
    },
    {
      "slug": "site_sections",
      "label": "Site Sections",
      "labelSingular": "Site Section",
      "description": "Reusable site-level sections rendered outside post content.",
      "supports": ["drafts", "revisions", "preview"],
      "urlPattern": "/",
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "required": true
        },
        {
          "slug": "links",
          "label": "Links",
          "type": "repeater",
          "validation": {
            "subFields": [
              {
                "slug": "label",
                "label": "Label",
                "type": "string",
                "required": true
              },
              {
                "slug": "url",
                "label": "URL",
                "type": "string",
                "required": true
              }
            ]
          }
        }
      ]
    }
  ],
  "content": {
    "posts": [],
    "site_sections": []
  }
}
