---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import { formatDate, getCurrentLocale, getHomePath, getPostPath, getPublicText, HOME_ABOUT_SLUG } from "../lib/i18n";
import { SITE_TITLE } from "../lib/seo";

type ProfileLink = {
    label: string;
    url: string;
};

const locale = getCurrentLocale(Astro.currentLocale);
const [siteSections, posts] = await Promise.all([
    getCollection("siteSections", ({ data }) => data.locale === locale && data.slug === HOME_ABOUT_SLUG),
    getCollection("posts", ({ data }) => data.locale === locale && !data.draft),
]);
const about = siteSections[0] ?? null;
const renderedAbout = about ? await render(about) : null;
const AboutContent = renderedAbout?.Content;

const sortedPosts = posts
    .filter((post) => post.data.slug.length > 0)
    .toSorted((a, b) => {
        const dateA = a.data.publishedAt?.getTime() ?? 0;
        const dateB = b.data.publishedAt?.getTime() ?? 0;
        return dateB - dateA;
    });

function isProfileLink(value: unknown): value is ProfileLink {
    if (!value || typeof value !== "object") return false;
    const link = value as Record<string, unknown>;
    return typeof link.label === "string" && typeof link.url === "string";
}

const profileLinks = Array.isArray(about?.data.links) ? about.data.links.filter(isProfileLink) : [];
const publicText = getPublicText(locale);
---

<Base title={SITE_TITLE} path={getHomePath(locale)}>
  <main>
    {
      about && (
        <section class="about" aria-label={publicText.aboutLabel}>
          {AboutContent && <AboutContent />}
          {
            profileLinks.length > 0 && (
              <ul class="profile-links">
                {profileLinks.map((link) => (
                  <li>
                    <a href={link.url}>{link.label}</a>
                  </li>
                ))}
              </ul>
            )
          }
        </section>
      )
    }
    {
      about && (
        <hr class="site-rule page-rule" />
      )
    }
    <section aria-label={publicText.postsLabel}>
      {
        sortedPosts.length === 0 ? (
          <p class="empty-posts">{publicText.emptyPosts}</p>
        ) : (
          sortedPosts.map((post) => (
            <article class="post-link">
              <p class="post-date">{formatDate(post.data.publishedAt)}</p>
              <a href={getPostPath(post.data.slug, locale)}>{post.data.title}</a>
              {post.data.description && <p class="post-description">{post.data.description}</p>}
            </article>
          ))
        )
      }
    </section>
  </main>
</Base>
