---
import { decodeSlug, getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { DEFAULT_LOCALE, formatDate, getCurrentLocale, getHomePath, getPostPath, getPublicText } from "../lib/i18n";

const slug = decodeSlug(Astro.params.slug);
const locale = getCurrentLocale(Astro.currentLocale);

const localizedPostResult = slug ? await getEmDashEntry("posts", slug, { locale }) : null;
const shouldFallbackToDefaultLocale = slug && locale !== DEFAULT_LOCALE && !localizedPostResult?.entry;
const defaultLocalePostResult = shouldFallbackToDefaultLocale
    ? await getEmDashEntry("posts", slug, { locale: DEFAULT_LOCALE })
    : null;
const postResult = defaultLocalePostResult?.entry ? defaultLocalePostResult : localizedPostResult;
const post = postResult?.entry ?? null;
if (postResult?.cacheHint) {
    Astro.cache.set(postResult.cacheHint);
}
const publicText = getPublicText(locale);
const homePath = getHomePath(locale);
const isNotFound = !slug || !post;

const publishedIso = post?.data.publishedAt?.toISOString() ?? null;
const modifiedIso = post?.data.updatedAt?.toISOString() ?? null;

if (isNotFound) {
    Astro.response.status = 404;
}
---

{
  isNotFound ? (
    <Base title={publicText.notFoundTitle} path={homePath}>
      <main>
        <section class="not-found">
          <h1>{publicText.notFoundTitle}</h1>
          <p>{publicText.notFoundMessage}</p>
          <p><a href={homePath}>{publicText.notFoundHomeLink}</a></p>
        </section>
      </main>
    </Base>
  ) : (
    <Base
      title={post.data.title}
      description={post.data.description}
      type="article"
      publishedTime={publishedIso}
      modifiedTime={modifiedIso}
      content={{ collection: "posts", id: post.data.id, slug: post.id }}
      path={getPostPath(post.id, locale)}
    >
      <main>
        <article class="prose prose-li:my-0.5 prose-ul:my-0.5 max-w-full mx-auto mt-8 mb-32 dark:prose-invert prose-pre:bg-surface">
          <header>
            {post.data.publishedAt && <small>{formatDate(post.data.publishedAt)}</small>}
            <h1>{post.data.title}</h1>
            {post.data.description && <p>{post.data.description}</p>}
          </header>
          <div>
            {post.data.content ? <PortableText value={post.data.content} /> : null}
          </div>
        </article>
      </main>
    </Base>
  )
}
